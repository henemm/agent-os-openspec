{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/modules/home-assistant/hooks/lovelace_screenshot_gate.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/modules/home-assistant/hooks/check_ha_restart.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
